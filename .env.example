# Public Supabase project URL. Safe for browser use when paired with RLS.
NEXT_PUBLIC_SUPABASE_URL=

# Public Supabase anonymous key. Safe for browser use when paired with RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only administrative key. Never expose through NEXT_PUBLIC_* variables.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only OpenAI API key.
OPENAI_API_KEY=

# Server-side model used for structured extraction and recovery drafts.
OPENAI_MODEL=gpt-5.6-luna

# Slug for the isolated synthetic demo project.
DEMO_PROJECT_SLUG=

# Server-only secret required by the demo reset operation.
DEMO_RESET_SECRET=
